<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PRQ.MVC</title>
    <style>
        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background: #f4f6f8;
            color: #1f2933;
        }

        header {
            background: #1f4b99;
            color: #fff;
            padding: 1rem 1.5rem;
        }

        header a {
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }

        main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        .panel {
            background: #fff;
            border-radius: 8px;
            padding: 1.25rem;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        }

        .actions,
        .filter-form,
        .form-grid {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            align-items: end;
        }

        .form-grid > div,
        .filter-form > div {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
            min-width: 180px;
        }

        input {
            padding: 0.55rem 0.7rem;
            border: 1px solid #cbd2d9;
            border-radius: 6px;
        }

        .btn {
            display: inline-block;
            padding: 0.6rem 0.9rem;
            border-radius: 6px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            background: #1f4b99;
            color: #fff;
        }

        .btn-secondary {
            background: #52606d;
        }

        .btn-danger {
            background: #c0392b;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
            background: #fff;
        }

        th,
        td {
            padding: 0.85rem;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        .text-danger {
            color: #c0392b;
        }

        dl {
            display: grid;
            grid-template-columns: 180px 1fr;
            gap: 0.75rem;
        }

        @@media (max-width: 768px) {
            main {
                padding: 1rem;
            }

            table,
            thead,
            tbody,
            tr,
            th,
            td {
                display: block;
            }

            thead {
                display: none;
            }

            td {
                padding-left: 0;
            }
        }
    </style>
</head>
<body>
    <header>
        <a asp-controller="Automoviles" asp-action="Index">Parking MVC - Automoviles</a>
    </header>

    <main>
        @RenderBody()
    </main>
</body>
</html>